{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/session_start_load_project_baseline.py\" --agents-md-path \"AGENTS.md\"",
            "statusMessage": "Loading project baseline"
          }
        ]
      }
    ]
  }
}
